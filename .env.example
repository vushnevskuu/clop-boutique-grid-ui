# Опционально: каталог из Medusa (админка — в отдельном проекте, см. medusa/README.md).
# Без этих переменных витрина использует только public/cloth/manifest.json.
#
# --- Локально ---
# VITE_MEDUSA_BACKEND_URL=http://localhost:9000
# или в dev с proxy из vite.config.ts:
# VITE_MEDUSA_BACKEND_URL=/medusa
#
# --- Vercel / прод (обязательно полный HTTPS URL бэкенда; /medusa proxy в проде не работует) ---
# VITE_MEDUSA_BACKEND_URL=https://api.ваш-домен.com
# VITE_MEDUSA_PUBLISHABLE_KEY=pk_...
#
# В Vercel: Project → Settings → Environment Variables (Production + Preview по желанию).
# После изменения переменных — Redeploy.
